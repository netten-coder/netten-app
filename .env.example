# Netten Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it contains secrets

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Get from Supabase: Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── AUTH SECRETS ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_char_hex_secret"
JWT_REFRESH_SECRET="replace_with_different_64_char_hex_secret"
MAGIC_LINK_SECRET="replace_with_another_64_char_hex_secret"

# ── EMAIL (Magic link login) ──────────────────────────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@netten.app"

# ── XRPL ─────────────────────────────────────────────────────────────────────
# Testnet (development): wss://s.altnet.rippletest.net:51233
# Mainnet (production):  wss://xrplcluster.com
XRPL_NODE_URL="wss://s.altnet.rippletest.net:51233"
# Get testnet wallet: https://xrpl.org/xrp-testnet-faucet.html
XRPL_PLATFORM_WALLET_SEED="sXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
XRPL_PLATFORM_WALLET_ADDRESS="rXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
RLUSD_ISSUER_ADDRESS="rHb9CJAWyB4rj91VRWn96DkukG4bwdtyTh"

# ── ALCHEMY PAY (Crypto → RLUSD conversion) ───────────────────────────────────
# Apply at: https://alchemypay.org/partner
ALCHEMY_PAY_APP_ID="your_app_id"
ALCHEMY_PAY_API_KEY="your_api_key"
ALCHEMY_PAY_SECRET_KEY="your_secret_key"
ALCHEMY_PAY_BASE_URL="https://openapi.alchemypay.org"

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="development"
# Your Railway API URL (after deployment)
API_URL="http://localhost:3001"

# ── WEB APP ───────────────────────────────────────────────────────────────────
# Your Vercel URL (after deployment)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
