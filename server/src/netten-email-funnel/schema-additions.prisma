// PRISMA SCHEMA ADDITIONS
// Add these to your existing schema.prisma
// ============================================

// Founding Member with email sequence tracking
model FoundingMember {
  id            String   @id @default(cuid())
  email         String   @unique
  firstName     String?
  spotNumber    Int      @unique // 1-777
  referralCode  String   @unique @default(cuid())
  referredBy    String?  // referralCode of referrer
  
  // Email sequence tracking
  emailSequenceStep Int      @default(0) // 0 = welcome sent, 1 = email 2 sent, etc.
  lastEmailSentAt   DateTime?
  nextEmailDue      DateTime?
  emailsOpened      Int      @default(0)
  lastOpenedAt      DateTime?
  isActive          Boolean  @default(true) // false if unsubscribed or gave up spot
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  referrals     FoundingMember[] @relation("Referrals")
  referrer      FoundingMember?  @relation("Referrals", fields: [referredBy], references: [referralCode])
  emailLogs     EmailLog[]
}

// Track individual email sends
model EmailLog {
  id              String   @id @default(cuid())
  foundingMemberId String
  foundingMember  FoundingMember @relation(fields: [foundingMemberId], references: [id])
  
  emailType       String   // email1_welcome, email2_problem, etc.
  subject         String
  sentAt          DateTime @default(now())
  openedAt        DateTime?
  clickedAt       DateTime?
  
  // Resend tracking
  resendId        String?
  status          String   @default("sent") // sent, opened, clicked, bounced, failed
  
  @@index([foundingMemberId])
  @@index([emailType])
}

// Global counters (for live 777 counter)
model GlobalCounter {
  id            String   @id @default("founding_members")
  count         Int      @default(0)
  updatedAt     DateTime @updatedAt
}
