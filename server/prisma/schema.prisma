// server/prisma/schema.prisma
// Netten database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE
  PAUSED
  SUSPENDED
  CANCELLED
}

enum PlanType {
  FOUNDING
  PRO
  STUDIO
}

enum AddOnType {
  CSV_EXPORT
  INVOICING
}

enum MerchantTier {
  FREE_BETA        // 10 spots - $0 forever, 1% fee
  EARLY_ADOPTER    // 55 spots - $33/mo forever, 1% fee
  FOUNDING         // 777 spots - $44/mo forever, 1% fee
  STARTER          // $55/mo, 1% fee
  PRO              // $77/mo, 1% fee
  BUSINESS         // $99/mo, 1% fee
  ENTERPRISE       // $999/mo, custom
}

// ── MERCHANT ──────────────────────────────────────────────────────────────────

model Merchant {
  id            String  @id @default(cuid())
  email         String  @unique
  businessName  String?
  country       String?
  timezone      String  @default("UTC")
  xrplAddress   String?
  isVerified    Boolean @default(false)
  isActive      Boolean @default(true)
  plan          String  @default("FOUNDING")
  
  // Beta Tester Fields
  tier              MerchantTier @default(FOUNDING)
  isBetaTester      Boolean      @default(false)
  betaStartDate     DateTime?
  betaEndDate       DateTime?
  betaNotes         String?
  betaWeeklyCheckin Int          @default(0)  // 0, 1, 2, 3 for check-in tracking
  
referralRewardPaid  Boolean   @default(false)
  rewardBalance       Float @default(0)
  totalRewardsEarned  Float @default(0)
  txnCountSinceReward Int   @default(0)
referralCode          String?   @unique
referredBy            String?
  auditAddon      Boolean   @default(false)
  auditAddonSince DateTime?
  sessionPreference String  @default("7d")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions  Transaction[]
  invoices      Invoice[]
  paymentLinks  PaymentLink[]
  rewardEvents  RewardEvent[]
  webhooks      Webhook[]
  magicTokens   MagicToken[]
  refreshTokens RefreshToken[]
  wallet        Wallet?
  subscription  Subscription?
  addOns        AddOn[]
  netTenCounter NetTenCounter?

  @@index([email])
}

// ── WALLET ────────────────────────────────────────────────────────────────────

model Wallet {
  id             String   @id @default(cuid())
  merchantId     String   @unique
  xrplAddress    String   @unique
  destinationTag Int      @unique
  createdAt      DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])
}

// ── SUBSCRIPTION ──────────────────────────────────────────────────────────────

model Subscription {
  id              String             @id @default(cuid())
  merchantId      String             @unique
  status          SubscriptionStatus @default(TRIAL)
  plan            PlanType           @default(FOUNDING)
  monthlyAmount   Decimal            @default(44.00)
  trialStartDate  DateTime           @default(now())
  trialEndDate    DateTime
  lastPaymentDate DateTime?
  nextDueDate     DateTime
  gracePeriodEnd  DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])
}

// ── ADD-ON ────────────────────────────────────────────────────────────────────

model AddOn {
  id         String    @id @default(cuid())
  merchantId String
  type       AddOnType
  amount     Decimal
  activeFrom DateTime  @default(now())
  activeTo   DateTime?
  createdAt  DateTime  @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
}

// ── NET TEN COUNTER ───────────────────────────────────────────────────────────

model NetTenCounter {
  id             String    @id @default(cuid())
  merchantId     String    @unique
  totalCount     Int       @default(0)
  currentQuarter Int       @default(1)
  rewardAmount   Decimal   @default(0.25)
  lastRewardDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])
}

// ── TRANSACTION ───────────────────────────────────────────────────────────────

model Transaction {
  id                String   @id @default(cuid())
  merchantId        String
  fromCoin          String
  fromAmount        Float?
  toAmount          Float
  netAmount         Float
  platformFeeAmount Float    @default(0)
  gasAmount         Float    @default(0)
  exchangeRate      Float?
  status            String   @default("PENDING")
  xrplTxHash        String?
  payAddress        String?
  payAmount         Float?
  description       String?
  source            String   @default("DIRECT")
  paymentLinkId     String?
  invoiceId         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  merchant    Merchant     @relation(fields: [merchantId], references: [id])
  rewardEvent RewardEvent?

  @@index([merchantId])
  @@index([status])
}

// ── INVOICE ───────────────────────────────────────────────────────────────────

model Invoice {
  id            String    @id @default(cuid())
  merchantId    String
  invoiceNumber String    @unique
  clientName    String
  clientEmail   String?
  amountUsd     Float
  acceptedCoins String[]
  status        String    @default("UNPAID")
  dueDate       DateTime?
  description   String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
}

// ── PAYMENT LINK ──────────────────────────────────────────────────────────────

model PaymentLink {
  id            String    @id @default(cuid())
  merchantId    String
  slug          String    @unique
  description   String
  amountUsd     Float?
  acceptedCoins String[]
  isActive      Boolean   @default(true)
  useCount      Int       @default(0)
  maxUses       Int?
  expiresAt     DateTime?
  url           String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([slug])
  @@index([merchantId])
}

// ── REWARD EVENT ──────────────────────────────────────────────────────────────

model RewardEvent {
  id            String   @id @default(cuid())
  merchantId    String
  type          String
  amountRlusd   Float
  transactionId String?  @unique
  xrplTxHash    String?
  description   String
  createdAt     DateTime @default(now())

  merchant    Merchant     @relation(fields: [merchantId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([merchantId])
}

// ── WEBHOOK ───────────────────────────────────────────────────────────────────

model Webhook {
  id         String   @id @default(cuid())
  merchantId String
  url        String
  events     String[]
  secret     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])
}

// ── AUTH ──────────────────────────────────────────────────────────────────────

model MagicToken {
  id         String   @id @default(cuid())
  merchantId String
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([token])
}

model RefreshToken {
  id         String   @id @default(cuid())
  merchantId String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])
}

// ── WAITLIST ──────────────────────────────────────────────────────────────────

model Waitlist {
  id            String   @id @default(cuid())
  email         String   @unique
  referralCode  String   @unique
  referredById  String?
  referralCount Int      @default(0)
  createdAt     DateTime @default(now())
}

model WaitlistEntry {
  id           String   @id @default(cuid())
  email        String   @unique
  referralCode String   @unique
  referredBy   String?
  createdAt    DateTime @default(now())
}

// ── Email Funnel Models ────────────────────────────────────────────────────

model FoundingMember {
  id                String    @id @default(cuid())
  email             String    @unique
  firstName         String    @default("")
  spotNumber        Int       @unique
  referralCode      String    @unique
  referredBy        String?
  emailSequenceStep Int       @default(0)
  nextEmailDue      DateTime?
  isActive          Boolean   @default(true)
  convertedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  emailLogs         EmailLog[]
}

model EmailLog {
  id              String   @id @default(cuid())
  foundingMemberId String
  foundingMember  FoundingMember @relation(fields: [foundingMemberId], references: [id])
  emailType       String
  resendId        String?
  status          String   @default("sent")
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime @default(now())
}

model GlobalCounter {
  id    String @id @default("founding_spots")
  value Int    @default(0)
}

// ── BETA TESTER TRACKING ─────────────────────────────────────────────────────

model BetaTester {
  id              String    @id @default(cuid())
  email           String    @unique
  businessName    String
  businessType    String?   // e.g., "Cafe/Apparel", "Freelancer", "DAO"
  contactName     String
  merchantId      String?   // Links to Merchant once they sign up
  
  // Beta Program Tracking
  status          String    @default("INVITED")  // INVITED, ONBOARDING, ACTIVE, COMPLETED, DROPPED
  startDate       DateTime?
  endDate         DateTime?
  
  // Check-in Tracking
  week1CheckIn    DateTime?
  week1Notes      String?
  week2CheckIn    DateTime?
  week2Notes      String?
  week3CheckIn    DateTime?
  week3Notes      String?
  
  // Metrics
  totalTransactions   Int    @default(0)
  totalVolume         Float  @default(0)
  successRate         Float  @default(0)
  bugsReported        Int    @default(0)
  
  // Outcome
  willContinue        Boolean?
  testimonialGiven    Boolean  @default(false)
  testimonialText     String?
  lifetimeFreeGranted Boolean  @default(false)
  
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
